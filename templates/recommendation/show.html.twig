{% extends 'base.html.twig' %}

{% block title %}Recommendation{% endblock %}

{% block body %}
    <h1>Recommendation</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ recommendation.id }}</td>
            </tr>
            <tr>
                <th>Type</th>
                <td>{{ recommendation.type }}</td>
            </tr>
            <tr>
                <th>Message</th>
                <td>{{ recommendation.message }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ recommendation.createdAt ? recommendation.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_recommendation_index') }}">back to list</a>

    <a href="{{ path('app_recommendation_edit', {'id': recommendation.id}) }}">edit</a>

    {{ include('recommendation/_delete_form.html.twig') }}
{% endblock %}
