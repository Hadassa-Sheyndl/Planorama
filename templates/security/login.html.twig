{% extends 'base_auth.html.twig' %}

{% block title %}Connexion - Planorama {% endblock %}

{% block body %}
<style>
    body, html { 
        margin: 0; padding: 0; height: 100%; 
        font-family: 'EBgaramond'; 
        overflow: hidden; 
    }

    .login-wrapper {
        display: flex;
        height: 100vh;
        width: 100%;
        /* L'image est mise sur le conteneur parent pour qu'elle soit partout en fond */
        background: url('{{ asset('img/accueil.png') }}') no-repeat center center;
        background-size: cover;
    }

    /* La partie gauche sert maintenant juste à pousser le texte ou laisser du vide */
    .left-content {
        flex: 1.2;
        display: flex;
        align-items: center;
        padding-left: 60px;
    }
    .left-content h1 { 
        color: #7d6b5d; font-size: 4rem; font-weight: 500; max-width: 450px; 
    }

/* Le panneau de formulaire mis à jour */
    .login-form-section {
        flex: 0.8;
        background-color: #e5e0db;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 0 1%;
        
        /* 1. ARRONDI ÉQUILIBRÉ (Haut et Bas identiques) */
        border-top-left-radius: 230px;
        border-bottom-left-radius: 230px;

        /* 2. BORDURE MARRON (Couleur du bouton #8b735b) */
        border: 4px solid #8b735b;
        border-right: none; /* On ne met pas de bordure à droite pour rester collé au bord */
        
        /* 3. OMBRE */
        box-shadow: -20px 0 50px rgba(0,0,0,0.15);

        /* 4. SÉCURITÉ */
        box-sizing: border-box; /* Pour que la bordure ne fasse pas déborder le bloc */
        z-index: 2;
    }

    .logo-house { 
        width: 275px;
        height: auto;      /* Garde les proportions de l'image */
        margin-bottom: 10px; 
        display: block;
        object-fit: contain; /* Évite que l'image soit déformée */
    }
    h2 { color: #7d6b5d; font-size: 2.5rem; margin-bottom: 30px; font-weight: 400; }
    p {color: #7d6d5b; font-family: EBgaramond; font-size: 1rem; font-weight: 600;}

    form { width: 100%; max-width: 350px; }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; color: #7d6b5d; margin-bottom: 8px; }
    .form-group input {
        width: 100%; padding: 12px 20px; border: 1px solid #d1ccc7;
        border-radius: 25px; background-color: #f3f0ee; box-sizing: border-box; outline: none;
    }
    .btn-submit {
        width: 100%; padding: 15px; background-color: #8b735b;
        color: white; border: none; border-radius: 30px; font-size: 1.1rem; cursor: pointer;
    }
    .link-switch { margin-top: 20px; color: #7d6b5d; text-decoration: underline; font-size: 1rem; font-weight: 600 }

/* Style pour le message de succès en blanc */
    .flash-success {
        margin-top: 50px;      /* Pour bien l'éloigner du lien s'inscrire */
        color: #FFFFFF;        /* Blanc pur */
        font-weight: 700;
        font-size: 1.4rem;
        text-align: center;
        /* Petite ombre pour que le blanc soit lisible sur le beige */
        text-shadow: 2px 2px 8px rgba(0,0,0,0.2); 
        animation: fadeIn 0.8s ease-in-out;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 900px) {
        .left-content { display: none; }
        .login-form-section { 
            flex: 1; border-radius: 0; width: 100%; 
            background-color: rgba(229, 224, 219, 0.95); /* Légère transparence sur mobile */
        }
    }
</style>

<div class="login-wrapper">
    <div class="left-content">
        <h1>Bienvenue chez... vous !</h1>
    </div>

    <div class="login-form-section">
        <img src="{{ asset('img/logo_marron.png') }}" alt="Logo Planorama" class="logo-house">
        <h2>Connexion</h2>

        <form method="post">
            {% if error %}
                <div style="color: #842029; background: #f8d7da; padding: 10px; border-radius: 8px; margin-bottom: 15px; text-align: center;">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <div class="form-group">
                <label for="inputEmail">Email</label>
                <input type="email" value="{{ app.request.query.get('email', last_username) }}" name="email" id="inputEmail" placeholder="adresse@gmail.com" required autofocus>
            </div>

            <div class="form-group">
                <label for="inputPassword">Mot de passe</label>
                <input type="password" name="password" id="inputPassword" placeholder="........." required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button class="btn-submit" type="submit">Se connecter</button>
        </form>

        <p> Pas encore de compte ?
        
        <a href="{{ path('app_register') }}" class="link-switch">S'inscrire</a>

        </p> 

        {% for message in app.flashes('success') %}
            <div class="flash-success">
                {{ message }}
            </div>
        {% endfor %}
    </div>


</div>
{% endblock %}