{% extends 'base.html.twig' %}

{% block title %}ItemCatalog{% endblock %}

{% block body %}
    <h1>ItemCatalog</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ item_catalog.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ item_catalog.name }}</td>
            </tr>
            <tr>
                <th>Category</th>
                <td>{{ item_catalog.category }}</td>
            </tr>
            <tr>
                <th>Style</th>
                <td>{{ item_catalog.style }}</td>
            </tr>
            <tr>
                <th>ImageSvg</th>
                <td>{{ item_catalog.imageSvg }}</td>
            </tr>
            <tr>
                <th>DefaultWidth</th>
                <td>{{ item_catalog.defaultWidth }}</td>
            </tr>
            <tr>
                <th>DefaultHeight</th>
                <td>{{ item_catalog.defaultHeight }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_item_catalog_index') }}">back to list</a>

    <a href="{{ path('app_item_catalog_edit', {'id': item_catalog.id}) }}">edit</a>

    {{ include('item_catalog/_delete_form.html.twig') }}
{% endblock %}
