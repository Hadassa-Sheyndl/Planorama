{% extends 'base.html.twig' %}

{% block title %}Mes plans{% endblock %}

{% block body %}

<style>
/* CONTAINER GLOBAL */
.plans-container {
    width: 80%;
    margin: 0 auto;
}

/* HEADER (titre + bouton) */
.plans-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
}

.plans-header h1 {
    color: #7d6b5d;
    text-align: center;
    flex: 1;
}

/* BOUTON CREATE */
.btn-create {
    background-color: #8b735b;
    color: white;
    padding: 12px 25px;
    border-radius: 25px;
    text-decoration: none;
    transition: 0.3s;
}

.btn-create:hover {
    background-color: #6f5c49;
}

/* TABLE CONTAINER */
.plans-table-container {
    background: rgba(255,255,255,0.6);
    backdrop-filter: blur(10px);
    padding: 30px;
    border-radius: 20px;
}

/* TABLE */
.plans-table {
    width: 100%;
    border-collapse: collapse;
}

/* HEADER TABLE */
.plans-table th {
    text-align: left;
    padding: 15px;
    color: #7d6b5d;
    border-bottom: 2px solid #dcd6d0;
}

/* LIGNES */
.plans-table td {
    padding: 15px;
    border-bottom: 1px solid #e5e0db;
}

/* HOVER LIGNE */
.plans-table tr:hover {
    background-color: rgba(139,115,91,0.1);
}

/* BOUTONS ACTION */
.btn-action {
    text-decoration: none;
    color: #8b735b;
    background-color: rgba(139,115,91,0.1);
    padding: 6px 12px;
    border-radius: 10px;
    font-size: 0.9rem;
    transition: 0.3s;
}

.btn-action:hover {
    background-color: #8b735b;
    color: white;
}


</style>
<div class="plans-container">

    <div class="plans-header">
        <h1>Mes plans</h1>

        <a href="{{ path('app_plan_new') }}" class="btn-create">
            + Créer un plan
        </a>
    </div>

    <div class="plans-table-container">
        <table class="plans-table">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Dimensions</th>
                    <th>Créé le</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for plan in plans %}
                <tr>
                    <td>{{ plan.name }}</td>
                    <td>{{ plan.width }} x {{ plan.height }}</td>
                    <td>{{ plan.createdAt ? plan.createdAt|date('d/m/Y') : '' }}</td>
                    <td>
                        <a href="{{ path('app_plan_show', {'id': plan.id}) }}" class="btn-action">Voir et ajuster le plan</a>
                        <br><br>
                        <a href="{{ path('app_plan_edit', {'id': plan.id}) }}" class="btn-action">Modifier les dimensions de la pièce</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4">Aucun plan</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

</div>

{% endblock %}