{% extends 'base_auth.html.twig' %}

{% block title %}Inscription - Planorama{% endblock %}

{% block body %}
<style>
    body, html { 
        margin: 0; padding: 0; height: 100%; 
        font-family: 'EBgaramond'; 
        overflow: hidden; 
    }

    .login-wrapper {
        display: flex;
        height: 100vh;
        width: 100%;
        background: url('{{ asset('img/accueil.png') }}') no-repeat center center;
        background-size: cover;
    }

    .left-content {
        flex: 1.2;
        display: flex;
        align-items: center;
        padding-left: 60px;
    }
    .left-content h1 { 
        color: #7d6b5d; font-size: 4rem; font-weight: 500; max-width: 450px; 
    }

    .login-form-section {
        flex: 0.8;
        background-color: #e5e0db;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 0 5%;
        border-top-left-radius: 150px;
        border-bottom-left-radius: 150px;
        border: 4px solid #8b735b;
        border-right: none;
        box-shadow: -20px 0 50px rgba(0,0,0,0.15);
        box-sizing: border-box;
        z-index: 2;
    }

    /* Style du logo identique à la connexion */
    .logo-house { 
        width: 275px;
        height: auto;
        margin-bottom: 10px; 
        display: block;
        object-fit: contain;
    }

    h2 { color: #7d6b5d; font-size: 2.5rem; margin-bottom: 30px; font-weight: 400; }
    p {color: #7d6d5b; font-family: EBgaramond; font-size: 1rem; font-weight: 600;}
    form { width: 100%; max-width: 350px; }
    
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; color: #7d6b5d; margin-bottom: 8px; }
    
    /* On force le style sur les inputs générés par Symfony */
    .form-group input {
        width: 100%; padding: 12px 20px; border: 1px solid #d1ccc7;
        border-radius: 25px; background-color: #f3f0ee; box-sizing: border-box; outline: none;
    }

    .btn-submit {
        width: 100%; padding: 15px; background-color: #8b735b;
        color: white; border: none; border-radius: 30px; font-size: 1.1rem; cursor: pointer;
        margin-top: 10px;
    }

    /* Style pour la case à cocher */
    .checkbox-group {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
        color: #7d6b5d;
    }
    .checkbox-group input { width: auto; margin: 0; }

    .link-switch { margin-top: 20px; color: #7d6b5d; text-decoration: underline; font-size: 1rem; font-weight: 600; }

    @media (max-width: 900px) {
        .left-content { display: none; }
        .login-form-section { flex: 1; border-radius: 0; width: 100%; background-color: rgba(229, 224, 219, 0.95); }
    }
</style>

<div class="login-wrapper">
    <div class="left-content">
        <h1>Bienvenue chez... vous !</h1>
    </div>

    <div class="login-form-section">
        <img src="{{ asset('img/logo_marron.png') }}" alt="Logo Planorama" class="logo-house">
        
        <h2>Inscription</h2>

        {{ form_start(registrationForm) }}

            <div class="form-group">
                {{ form_label(registrationForm.pseudo, 'Pseudo') }}
                {{ form_widget(registrationForm.pseudo) }}
                {{ form_errors(registrationForm.pseudo) }}
            </div>
            <div class="form-group">
                {{ form_label(registrationForm.email, 'Email') }}
                {{ form_widget(registrationForm.email) }}
                {{ form_errors(registrationForm.email) }}
            </div>

            <div class="form-group">
                {{ form_label(registrationForm.plainPassword, 'Mot de passe') }}
                {{ form_widget(registrationForm.plainPassword) }}
                {{ form_errors(registrationForm.plainPassword) }}
            </div>

            <div class="checkbox-group">
                {{ form_widget(registrationForm.agreeTerms) }}
                {{ form_label(registrationForm.agreeTerms, 'J\'accepte les conditions') }}
            </div>
            {{ form_errors(registrationForm.agreeTerms) }}

            <button type="submit" class="btn-submit">S'inscrire</button>
        {{ form_end(registrationForm) }}

        <p> Déjà un compte ?
        <a href="{{ path('app_login') }}" class="link-switch">Se connecter</a>
        </p>
    
    </div>
</div>
{% endblock %}